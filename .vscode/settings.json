{
  // Keeps node_modules out of the file tree, search results, and the file
  // watcher. Without this, it's easy to accidentally open a file that
  // belongs to an installed package (like @refinedev/core's own
  // tsconfig.json) and see confusing "problems" that come from that
  // package's own internal build setup — nothing to do with our code, and
  // editing those files wouldn't do anything anyway since npm overwrites
  // them on every install.
  "files.exclude": {
    "**/node_modules": true
  },
  "search.exclude": {
    "**/node_modules": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true
  }
}
